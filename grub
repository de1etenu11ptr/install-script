# GRUB boot loader configuration

GRUB_DEFAULT=0
GRUB_TIMEOUT=-1
GRUB_DISTRIBUTOR="Arch"
# `systemd.unified_cgroup_hierarchy=1` enables cgroups v2 support to enforce memory limits (might break programs using cgroups v1_
# `swapaccount=1` enables limiting swap usage as cgroups only enforces memory limits for RAM and not swap
GRUB_CMDLINE_LINUX_DEFAULT="loglevel=7 printk.time=1 printk.always_kmsg_dump=1 printk.devkmsg=ratelimit systemd.unified_cgroup_hierarchy=1 swapaccount=1"
GRUB_CMDLINE_LINUX=""

# Preload both GPT and MBR modules so that they are not missed
GRUB_PRELOAD_MODULES="part_gpt part_msdos"

GRUB_TIMEOUT_STYLE=menu
GRUB_TERMINAL_INPUT=console

GRUB_GFXMODE=auto

GRUB_GFXPAYLOAD_LINUX=keep

GRUB_DISABLE_RECOVERY=true

# Entries specified as foreground/background.
GRUB_COLOR_NORMAL="light-blue/black"
GRUB_COLOR_HIGHLIGHT="light-cyan/blue"

# Uncomment one of them for the gfx desired, a image background or a gfxtheme
#GRUB_BACKGROUND="/path/to/wallpaper"
#GRUB_THEME="/path/to/gfxtheme"
